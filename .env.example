# LLM - use groq (free) or ollama (local) to avoid OpenAI costs
LLM_PROVIDER=groq
GROQ_API_KEY=gsk-your-groq-key
OPENAI_API_KEY=sk-your-openai-key

# Scraping (Firecrawl - get free tier at firecrawl.dev)
FIRECRAWL_API_KEY=fc-your-firecrawl-key

# Infrastructure
REDIS_URL=redis://localhost:6379/0
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/sdr_agent

# Monitoring (Helicone - get key at helicone.ai)
HELICONE_API_KEY=your-helicone-key

# Optional: Use Helicone as OpenAI proxy
OPENAI_BASE_URL=https://oai.hconeai.com/v1
